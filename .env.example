# Server
PORT=4000
NODE_ENV=development

# MongoDB (must match config — variable name is MONGO_URI)
MONGO_URI=mongodb://localhost:27017/anginat-admin

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
TTS_S3_BUCKET=anginat-tts-bucket
STT_S3_BUCKET=anginat-stt-bucket

# Google Cloud
GOOGLE_CLOUD_PROJECT_ID=your_google_project_id
GOOGLE_TTS_PRIVATE_KEY=your_google_tts_private_key
GEMINI_API_KEY=your_gemini_api_key

# Sarvam AI
SARVAM_API_KEY=your_sarvam_api_key

# Python TTS Backend
PYTHON_TTS_BACKEND_URL=http://localhost:8000

# Audio Storage
AUDIO_STORAGE_PROVIDER=S3

# API Auth
API_AUTH_BYPASS=false

# Rate Limiting
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=60

# CORS
CORS_ORIGINS=http://localhost:3000

# Forward /api/course and /api/student to this host (admin frontend uses one API base URL).
EXTERNAL_STUDENT_API_ORIGIN=https://studentapi.anginatlearning.com

# Email Config
EMAIL_PROVIDER=none
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=

# SendGrid (required for password reset OTP email)
SENDGRID_API_KEY=your_sendgrid_api_key
OTP_EMAIL=noreply@yourdomain.com
VERIFY_OTP_SECRET=your_verify_otp_jwt_secret

# Security
BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_EXPIRY=600000
EMAIL_CONFIRMATION_EXPIRY=86400000

# File Uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=mp3,wav,flac,ogg

# Logging
LOG_LEVEL=info

# Feature Flags
FEATURE_EMAIL_CONFIRMATION=false
FEATURE_OAUTH_LOGIN=false
FEATURE_VOICE_CLONING=false
FEATURE_ANALYTICS=false
